---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import ShortHeader from "@/components/ui/ShortHeader.astro";
import InsightFilter from "@/components/ui/InsightFilter.astro";
import Search from "astro-pagefind/components/Search";


---

<BaseLayout SEOTitle="Insights">
  <ShortHeader title="Insights" subtitle="Read all of our public works" />
  <main class="px-6 max-w-screen-2xl mx-auto">
    <br>
    <BreadCrumbsDefault />
    <section class="pt-16">
      <div class="pb-8">
        <h1 class="text-6xl pb-10">Publications</h1>

        {/* Two-column layout for aside and main content */}
        <div class="flex flex-col md:flex-row gap-8">
          {/* Aside (Filter) - Left Side */}
          <aside class="w-full md:w-1/4 lg:w-1/5">
            <InsightFilter />
          </aside>

{/* Main Content - Right Side */}
<div class="w-full md:w-3/4 lg:w-4/5" 
     x-data="insightsFilter()" 
     @filter-update.window="updateFilters($event.detail)">
  
  <!-- Inject JSON Data into a Script Tag -->
  <script type="application/json" id="insights-data">
    {JSON.stringify(sortedInsights)}
  </script>
<div id="search"></div>


<Search id="search" className="pagefind-ui" uiOptions={{ showImages: false }} />

  <!-- Publications Grid -->


  <!-- No Results -->
  <div x-show="filteredInsights.length === 0" class="text-center text-gray-500 py-8">
    No matching insights found.
  </div>
</div>



          <!-- {/* Main Content (Publications List) - Right Side */}
          <div class="w-full md:w-3/4 lg:w-4/5 space-y-8">
            {sortedInsights.map((entry, index) => (
              <article
                class="group p-6 hover:bg-gray-50/50 transition-colors rounded-xl"
                id={publication-${index}}
              >
                {/* Flex container for responsive layout */}
                <div class="flex flex-col md:flex-row gap-4 md:gap-6">
                  {/* Image Card - 50% width on desktop */}
                  <div class="w-full md:w-1/2 lg:w-[30%] xl:w-[25%] hidden md:block">
                    <PCard
                      title={entry.data.title}
                      date={entry.data.pubDate.toLocaleDateString(undefined, {
                        dateStyle: "medium",
                        timeZone: "UTC",
                      })}
                      category="Publication"
                      imgSrc={entry.data.cardImage}
                      imgAlt={entry.data.title}
                      link={/publications/${entry.slug}}
                      class="h-full"
                    />
                  </div>

                  {/* Content - 50% width on desktop */}
                  <div class="w-full md:w-1/2 lg:w-[70%] xl:w-[75%] space-y-3">
                    <div class="space-y-3">
                      <a
                        href={/publications/${entry.slug}}
                        class="text-2xl font-bold text-gray-900 hover:text-blue-600 transition-colors"
                      >
                        {entry.data.title}
                      </a>

                      <div class="flex flex-wrap gap-2 text-sm font-medium">
                        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full">
                          Publication
                        </span>
                        <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                          {entry.data.pubDate.toLocaleDateString(undefined, {
                            dateStyle: "medium",
                            timeZone: "UTC",
                          })}
                        </span>
                      </div>

                      <p class="text-gray-600 font-medium">
                        Authors: <span class="text-gray-800">{entry.data.authors.join(", ")}</span>
                      </p>
                    </div>

                    <p class="text-gray-700 leading-relaxed line-clamp-3">
                      {entry.body}
                    </p>

                    <a
                      href={/publications/${entry.slug}}
                      class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium transition-colors"
                    >
                      Read more
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 ml-1"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </a>
                  </div>
                </div>

                {/* Divider - only between items */}
                {index < sortedInsights.length - 1 && (
                  <hr class="my-8 border-t border-gray-200" />
                )}
              </article>
            ))}
          </div>
        </div>
      </div> -->


    </section>
  </main>
 
</BaseLayout>