  <!-- Alpine.js Pagination Script -->
  <script>
    document.addEventListener("alpine:init", () => {
      Alpine.data("paginationComponent", () => ({
        publications: [],
        currentPage: 1,
        itemsPerPage: 2,
        totalPages: 1,

        initPublications(jsonData) {
          this.publications = JSON.parse(jsonData);
          this.totalPages = Math.ceil(
            this.publications.length / this.itemsPerPage
          );
        },

        get paginatedPublications() {
          let start = (this.currentPage - 1) * this.itemsPerPage;
          return this.publications.slice(start, start + this.itemsPerPage);
        },

        nextPage() {
          if (this.currentPage < this.totalPages) {
            this.currentPage++;
          }
        },

        previousPage() {
          if (this.currentPage > 1) {
            this.currentPage--;
          }
        },
      }));
    });
  </script>

  <!-- Alpine.js -->
