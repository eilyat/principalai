---
import '@/styles/global.css';
import BaseLayout from '@/components/BaseLayout.astro';
---

<BaseLayout SEOTitle="Page not found" SEODescription="The page you are looking for could not be found.">
  <section>
    <div class="container mx-auto flex min-h-screen items-center justify-center px-6 py-12">
      <div class="text-center">
        <p class="text-8xl font-medium text-blue-600">404</p>
        <h1 class="mt-3 text-2xl font-semibold text-gray-900">Page not found</h1>
        <p class="mt-4 text-gray-500">We could not find the page you were looking for.</p>

        <div class="mt-6 flex justify-center gap-3">
          <button
            type="button"
            onclick="history.back()"
            class="rounded-md border border-gray-300 px-5 py-2 font-sans text-gray-700 hover:bg-gray-100"
          >
            Go back
          </button>

          <a
            href="/"
            class="rounded-md bg-blue-600 px-5 py-2 font-sans text-white hover:bg-blue-700"
          >
            Home
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
