---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import ShortHeader from "@/components/ui/ShortHeader.astro";
import LeftTitleBlock from "@/components/ui/LeftTitleBlock.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout SEOTitle="Corporate Commitments">
  <ShortHeader
    title="Corporate commitments"
    subtitle="Guiding principles for sustainable and inclusive growth"
  />
  <main class="px-6 max-w-screen-2xl items-center justify-center mx-auto">
    <br />
    <BreadCrumbsDefault />
    <br />
    <section class="pt-16">
      <div class="pb-8">
        <div class="post-wrapper">

          <LeftTitleBlock>
            <div slot="title">Our corporate commitments</div>
            <div slot="content">
              <p class="text-gray-700 mb-4">
                We are continuously learning, improving, and adapting our practices to meet the evolving needs of our clients and society. These commitments are not just words; they are the guiding principles that shape our decisions, actions, and the positive impact we aim to create.
              </p>              
            </div>
          </LeftTitleBlock>
          <hr class="my-8 border-t border-gray-200" />


          <LeftTitleBlock>
            <div slot="title">Economic and social impact</div>
            <div slot="content">
              <h2>Inclusive growth</h2>
              <p class="text-gray-700 mb-4">
                We are committed to promoting inclusive growth by leveraging our expertise to support policies, projects, and initiatives that foster economic development and reduce inequalities. We believe in creating opportunities for all individuals and communities to thrive, empowering them through economic analysis and evidence-based recommendations.
              </p>  
              <h2>Working with Communities</h2>
              <p class="text-gray-700 mb-4">
                We believe in the power of collaboration and actively seek opportunities to work with communities. By engaging with local stakeholders, we gain valuable insights, develop a deep understanding of economic dynamics, and contribute to sustainable solutions that address community needs. We strive to be a trusted partner and a catalyst for positive change.</p>  
            </div>
          </LeftTitleBlock>
          <hr class="my-8 border-t border-gray-200" />

          <LeftTitleBlock>
            <div slot="title">Our people and culture</div>
            <div slot="content">
              <h2>Diversity and inclusion</h2>
              <p class="text-gray-700 mb-4">
                Diversity and inclusion are essential pillars of our firm’s culture and success. We are committed to cultivating a diverse and inclusive workforce that reflects a richness of perspectives, experiences, and backgrounds. By fostering an inclusive environment, we unlock innovation and creativity, enabling us to better serve our clients and society.
              </p>  
              <h2>Health and safety</h2>
              <p class="text-gray-700 mb-4">
                We are committed to ensuring the health, safety, and well-being of our employees, clients, and partners. We maintain a safe and supportive work environment, adhering to health and safety regulations and best practices. By prioritizing the physical and mental well-being of our team, we foster a culture of care and productivity.
              </p>  
            </div>
          </LeftTitleBlock>
          <hr class="my-8 border-t border-gray-200" />

          <LeftTitleBlock>
            <div slot="title">Our ethical standards</div>
            <div slot="content">
              <p class="text-gray-700 mb-4">
                Integrity is at the core of everything we do. We uphold the highest ethical standards in our interactions with clients, colleagues, and stakeholders. Transparency, honesty, and accountability guide our work, ensuring that our recommendations are based on rigorous analysis and free from conflicts of interest. Trust is the foundation of our relationships.
              </p>  
            </div>
          </LeftTitleBlock>
          <hr class="my-8 border-t border-gray-200" />

          <LeftTitleBlock>
            <div slot="title">Sustainability and responsibility</div>
            <div slot="content">
              <p class="text-gray-700 mb-4">
                We recognise the urgent need to address environmental challenges and contribute to sustainable development. We integrate sustainability considerations into our work, helping our clients navigate the transition towards a more sustainable and resilient future. We strive to minimize our environmental footprint, promote resource efficiency, and support initiatives that drive positive environmental impact.
              </p>  
            </div>
          </LeftTitleBlock>
          <hr class="my-8 border-t border-gray-200" />


    </section>
  </main>
</BaseLayout>
