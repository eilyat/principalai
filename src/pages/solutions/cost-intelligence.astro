---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
---

<BaseLayout
  SEOTitle="Cost Intelligence Platform | PrincipalAI"
  SEODescription="Market and cost intelligence for forecasting, investment planning, and decision support."
>
  <section class="bg-gradient-to-r from-[#071f3f] via-[#123f86] to-[#e8f4ff] px-8 py-24 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-blue-100">
        Cost Intelligence Platform
      </p>
      <h1 class="max-w-4xl font-serif text-5xl font-bold leading-tight sm:text-6xl">
        Cost intelligence for better investment decisions.
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-relaxed text-blue-50">
        The Cost Intelligence Platform helps organisations monitor changing market conditions, structure cost evidence, and support timely forecasting decisions.
      </p>
    </div>
  </section>

  <main>
    <section class="bg-white px-8 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">
            The problem
          </p>
          <h2 class="font-serif text-4xl font-bold leading-tight text-gray-900">
            Cost assumptions can become outdated before decisions are made.
          </h2>
        </div>
        <div class="space-y-5 text-lg leading-relaxed text-gray-700">
          <p>
            Infrastructure, energy, transport, housing, and public investment decisions often depend on cost assumptions formed under changing market conditions.
          </p>
          <p>
            The Cost Intelligence Platform supports more responsive decision-making by helping organisations organise cost evidence, monitor relevant signals, and update forecasts more consistently.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 px-8 py-20">
      <div class="mx-auto max-w-7xl">
        <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">
          What it supports
        </p>
        <h2 class="max-w-3xl font-serif text-4xl font-bold leading-tight text-gray-900">
          Designed for teams that need clearer cost signals.
        </h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Market monitoring</h3>
            <p class="mt-4 text-gray-700">
              Track relevant cost drivers and market indicators to support timely planning.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Forecast support</h3>
            <p class="mt-4 text-gray-700">
              Structure cost evidence and assumptions for more consistent forecast updates.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Scenario testing</h3>
            <p class="mt-4 text-gray-700">
              Explore cost risks, sensitivities, and alternative planning assumptions.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Decision reporting</h3>
            <p class="mt-4 text-gray-700">
              Convert cost signals into clearer advice for investment and procurement decisions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white px-8 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">
            Why PrincipalAI
          </p>
          <h2 class="font-serif text-4xl font-bold leading-tight text-gray-900">
            Cost intelligence grounded in economic and market analysis.
          </h2>
        </div>
        <div class="space-y-5 text-lg leading-relaxed text-gray-700">
          <p>
            PrincipalAI combines AI-enabled workflows with Principal Economics’ experience in cost escalation, economic appraisal, infrastructure, energy, and market analysis.
          </p>
          <p>
            The platform is designed to support professional judgement rather than replace it, helping teams move from static assumptions to more adaptive decision support.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-[#071f3f] px-8 py-20 text-white">
      <div class="mx-auto max-w-7xl text-center">
        <h2 class="mx-auto max-w-4xl font-serif text-4xl font-bold leading-tight">
          Make cost evidence easier to monitor, update, and use.
        </h2>
        <p class="mx-auto mt-5 max-w-3xl text-lg leading-relaxed text-blue-50">
          Talk to PrincipalAI about cost intelligence for investment planning, forecasting, procurement, and strategic decision support.
        </p>
        <a
          href="/contact"
          class="mt-8 inline-block rounded-md bg-blue-600 px-7 py-3 font-semibold text-white hover:bg-blue-700"
        >
          Request a demonstration
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
