---
// import BaseHead from '../../components/BaseHead.astro';
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
// import FormattedDate from "../../components/FormattedDate.astro";
import NavBar from "../../components/menu/NavBar.astro";
import BreadCrumbsDefault from "../../components/ui/BreadCrumbsDefault.astro";
import RightArrow from "../../components/ui/RightArrow.astro";

import "../../styles/global.css";

const posts = await getCollection("industries");

import "astro-breadcrumbs/breadcrumbs.css";
---

<!doctype html>
<html lang="en">
	<head>
		<script
			defer
			src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"
		></script>
		<script
			defer
