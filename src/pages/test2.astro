---
import Industries from "./IndustriesMenu.astro";
import Capabilities from "./CapabilitiesMenu.astro";
import DropDown from "./DropDown.astro";
---

<nav
    x-data="{ open: false, navigationMenu: '', 
    toggleMenu(menu) { this.navigationMenu = this.navigationMenu === menu ? '' : menu; this.open = this.navigationMenu ? true : false; }, 
    navigationMenuClose() { this.navigationMenu = ''; this.open = false; } }"
    @keydown.esc.window="open = false"
    @click.outside="open = false"
    x-ref="nav"
>
    <div class="place-items-start items-center h-full">
        <ul class="flex flex-row h-full">
            <li class="toggleable hover:bg-gray-100 hover:text-black h-full">
                <!-- Industries button -->
                <li>
                    <button
                        @click="toggleMenu('industries')"
                        @keydown.space.prevent="toggleMenu('industries')"
                        @keydown.enter.prevent="toggleMenu('industries')"
                        @keydown.down.prevent="toggleMenu('industries')"
                        aria-label="industries-menu"
                        class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
                    >
                        Industries
                    </button>
                </li>
                <!-- Capabilities button -->
                <li>
                    <button
                        @click="toggleMenu('capabilities')"
                        @keydown.space.prevent="toggleMenu('capabilities')"
                        @keydown.enter.prevent="toggleMenu('capabilities')"
                        @keydown.down.prevent="toggleMenu('capabilities')"
                        aria-label="capabilities-menu"
                        class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
                    >
                        Capabilities
                    </button>
                </li>
                <!-- Insights button -->
                <li>
                    <button
                        @click="toggleMenu('insights')"
                        @keydown.space.prevent="toggleMenu('insights')"
                        @keydown.enter.prevent="toggleMenu('insights')"
                        @keydown.down.prevent="toggleMenu('insights')"
                        aria-label="insights-menu"
                        class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
                    >
                        Insights
                    </button>
                </li>
                <!-- About us button -->
                <li>
                    <button
                        @click="toggleMenu('about-us')"
                        @keydown.space.prevent="toggleMenu('about-us')"
                        @keydown.enter.prevent="toggleMenu('about-us')"
                        @keydown.down.prevent="toggleMenu('about-us')"
                        aria-label="about-us-menu"
                        class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
                    >
                        About us
                    </button>
                </li>
                <!-- Contact us button -->
                <li>
                    <button
                        @click="toggleMenu('contact-us')"
                        @keydown.space.prevent="toggleMenu('contact-us')"
                        @keydown.enter.prevent="toggleMenu('contact-us')"
                        @keydown.down.prevent="toggleMenu('contact-us')"
                        aria-label="contact-us-menu"
                        class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
                    >
                        Contact us
                    </button>
                </li>
            </li>
        </ul>
    </div>
    
    <!-- Menu panel control -->
    <div
        x-show="open"
        x-collapse
        x-trap="open"
        x-cloak
        x-anchor.no-style="$refs.nav"
        x-bind:style="{ position: 'absolute', top: $anchor.y, left: '0px' }"
        @click.outside="isOpened = false, openedWithKeyboard = false"
        @keydown.down.prevent="$focus.wrap().next()"
        @keydown.up.prevent="$focus.wrap().previous()"
        class="absolute rounded-md shadow-md max-w-full w-full sm:flex-col z-50 left-0"
    >
        <div>
        <!-- Menu panel components start -->
            <!-- Industries menu -->
            <template x-if="navigationMenu === 'industries'">
                <Industries />
            </template>
            <!-- Capabilities menu -->
            <template x-if="navigationMenu === 'capabilities'">
                <Capabilities />
            </template>
            <!-- Insights menu -->
            <template x-if="navigationMenu === 'insights'">
                <Capabilities />
            </template>
            <!-- About us menu -->
            <template x-if="navigationMenu === 'about-us'">
                <Capabilities />
            </template>
            <!-- Contact us menu -->
            <template x-if="navigationMenu === 'contact-us'">
                <Capabilities />
            </template>
        </div>
    </div>

    <!-- <DropDown title = "Test" ><Industries /> </DropDown> -->

    <!-- <DropDown title = "Test2" ><Industries /> </DropDown> -->
</nav>

<style>
    [x-cloak] {
        display: none;
    }
</style>
