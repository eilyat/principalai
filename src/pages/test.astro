---
// src/pages/insights.astro
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import ShortHeader from "@/components/ui/ShortHeader.astro";
import { getCollection } from "astro:content";
import Pcard from "@/components/ui/pCard.astro"

const team = await getCollection("team");

import { getCollection } from "astro:content";
const publications = await getCollection("publications");
const articles = await getCollection("articles");
const resources = await getCollection("resources");

// Combine all collections into a single array
const allInsights = [
  ...publications.map(pub => ({ ...pub, type: "publications" })),
  ...articles.map(art => ({ ...art, type: "articles" })),
  ...resources.map(res => ({ ...res, type: "resources" }))
];

// Sort the combined array by date
const sortedInsights = allInsights.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA; // Sort in descending order (most recent first)
});

// const filteredInsights = sortedInsights.filter(insight => 
//   insight.data.authors.includes(frontmatter.name)
// );


