    <!-- <section class="pt-16"> -->
      <style>
        /* Hide scrollbar for all browsers */
        .scroll-container::-webkit-scrollbar { display: none; }
        .scroll-container { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Snap scrolling */
        .scroll-container { scroll-snap-type: x mandatory; }
        .scroll-item { scroll-snap-align: start; }
        
        /* Hover effects */
        .scroll-item { transition: transform 0.2s ease; }
        .scroll-item:hover { transform: translateY(-4px); }
        
        /* Gradient fade overlay */
        .gradient-overlay::after {
          content: '';
          position: absolute;
          right: 0;
          top: 0;
          bottom: 0;
          width: 60px;
          background: linear-gradient(to right, transparent 0%, var(--bg-color) 100%);
          pointer-events: none;
        }
        .scroll-button:disabled {
        @apply opacity-50 cursor-not-allowed hover:scale-100;
        }
      </style>

      <!-- Full-bleed scrolling container with proper margins -->
      <div class="-mx-6 relative gradient-overlay" style="--bg-color: #ffffff">
        <div class="scroll-container overflow-x-auto px-6">
          <div class="flex gap-6 w-max min-w-full pb-4">
            {sortedInsights.map((entry, index) => (
              <div class="w-full">
                <Pcard
                  title={entry.data.title}
                  date={entry.data.pubDate.toLocaleDateString(undefined, {
                    dateStyle: "medium",
                    timeZone: "UTC",
                  })}
                  category={String(entry.data.type)}
                  imgSrc={entry.data.cardImage}
                  imgAlt={entry.data.title}
                  link={`/${entry.type || "default"}/${entry.slug || "default"}`}
                  class="h-full"
                />
  
              </div>
            ))}

          </div>
        </div>
      </div>

      <div class="-mx-6 relative gradient-overlay" style="--bg-color: #ffffff">
        <!-- Navigation buttons -->
        <button id="scrollLeft" class="scroll-button absolute left-4 top-1/2 -translate-y-1/2"
        aria-label="Scroll left" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="sr-only">Scroll left</span>
        </button>
        
        <button id="scrollRight" class="scroll-button absolute right-4 top-1/2 -translate-y-1/2"   aria-label="Scroll right"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <span class="sr-only">Scroll right</span>
        </button>

        <div class="scroll-container overflow-x-auto px-6">
          <!-- Keep existing scroll content the same -->
        </div>
      </div>
      <script is:inline>
        // Add to existing DOMContentLoaded handler
        const updateButtonStates = () => {
          const container = document.querySelector('.scroll-container');
          const scrollLeft = document.getElementById('scrollLeft');
          const scrollRight = document.getElementById('scrollRight');
          
          if (!container || !scrollLeft || !scrollRight) return;
          
          // Tolerance of 5px for edge detection
          scrollLeft.disabled = container.scrollLeft < 5;
          scrollRight.disabled = container.scrollLeft + container.offsetWidth >= 
                                container.scrollWidth - 5;
        };
      
        // Update on scroll and resize
        document.querySelector('.scroll-container')?.addEventListener('scroll', updateButtonStates);
        window.addEventListener('resize', updateButtonStates);
        // Initial check
        updateButtonStates();
      </script>
      <!-- Updated keyboard and button navigation -->
      <script is:inline>
        // Calculate scroll amount based on card width
        const getScrollAmount = () => {
          const firstItem = document.querySelector('.scroll-item');
          if (!firstItem) return 300; // Fallback to 300px
          const style = window.getComputedStyle(firstItem);
          return firstItem.offsetWidth + 
                 parseInt(style.marginLeft) + 
                 parseInt(style.marginRight) +
                 24; // Add gap-6 (1.5rem = 24px)
        };
      
        // Unified scroll function
        const scrollContainer = (direction) => {
          const container = document.querySelector('.scroll-container');
          if (!container) return;
          
          const amount = getScrollAmount() * direction;
          container.scrollBy({ left: amount, behavior: 'smooth' });
        };
      
        // Event listeners
        document.addEventListener('DOMContentLoaded', () => {
          // Button controls
          document.getElementById('scrollLeft')?.addEventListener('click', () => scrollContainer(-1));
          document.getElementById('scrollRight')?.addEventListener('click', () => scrollContainer(1));
          
          // Keyboard controls
          document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowLeft') scrollContainer(-1);
            if (e.key === 'ArrowRight') scrollContainer(1);
          });
      
          // Handle window resize
          let resizeTimeout;
          window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
              // Update scroll position after resize
              const container = document.querySelector('.scroll-container');
              container.scrollLeft = Math.round(container.scrollLeft / getScrollAmount()) * getScrollAmount();
            }, 100);
          });
        });
      </script>
