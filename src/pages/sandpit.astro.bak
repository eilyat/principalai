			<article class="lg:col-span-8 xl:col-span-9">
        <div class="prose lg:prose-xl max-w-none">
          <h1>Dynamic Plotly Graph with Seed</h1>
          
          <!-- Input for the seed value -->
          <input type="number" id="seedInput" placeholder="Enter seed value" class="border p-2 mb-4" />

          <!-- Button to update the chart -->
          <button id="update-plotly" class="bg-blue-500 text-white p-2 rounded">
            Update Chart Data
          </button>

          <!-- Chart container -->
          <div id="plotly-container">
            <p>Chart will render here.</p>
          </div>
        </div>
      </article>



		</div>
        <br><br>
	</main>
	
