const { frontmatter } = Astro.props;

---

<BaseLayout SEOTitle="Publications">
	<script src="https://unpkg.com/htmx.org@1.9.10"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/plotly.js/1.33.1/plotly.min.js" charset="utf-8"></script>

	<ShortHeader title="Testing" subtitle="Elements">		
	</ShortHeader>
	<main class="px-4 md:px-6 max-w-screen-2xl mx-auto">
		<div class="py-6"></div>
			<!-- Main Content -->

			<!-- <article class="lg:col-span-8 xl:col-span-9">
