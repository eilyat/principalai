	<script>
    async function fetchAndRenderPlotly() {
      try {
        // Get the seed value from the input field
        const seedValue = document.getElementById("seedInput").value;
        // Construct the API URL with the seed query parameter (if provided)
        const apiUrl = seedValue 
          ? `http://localhost:8000/randomPlot?seed=${seedValue}` 
          : "http://localhost:8000/randomPlot";
        
        console.log("Fetching Plotly JSON from:", apiUrl);
        const response = await fetch(apiUrl);
        const data = await response.json();
        console.log("Received Plotly JSON:", data);

        // Update the chart container
        const container = document.getElementById("plotly-container");
        container.innerHTML = "<div id='plotly-chart'></div>";

        // Render the Plotly chart with the new data
        Plotly.newPlot("plotly-chart", data.data, data.layout);
        console.log("Chart updated successfully.");
      } catch (error) {
        console.error("Error fetching or rendering Plotly chart:", error);
      }
    }

    // Attach event listener to the button
    document.getElementById("update-plotly").addEventListener("click", fetchAndRenderPlotly);

    // Optionally, load the chart automatically on page load
    window.addEventListener("DOMContentLoaded", fetchAndRenderPlotly);
  </script>


</BaseLayout>


