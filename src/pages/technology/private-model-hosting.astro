---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
---

<BaseLayout
  SEOTitle="Local and Private Model Hosting | PrincipalAI"
  SEODescription="Private model hosting for organisations that need secure, controlled, and flexible AI deployment."
>
  <section class="bg-gradient-to-r from-[#071f3f] via-[#123f86] to-[#e8f4ff] px-8 py-24 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-blue-100">
        Local and Private Model Hosting
      </p>

      <h1 class="max-w-5xl font-serif text-5xl font-bold leading-tight sm:text-6xl">
        Host AI models in environments you control.
      </h1>

      <p class="mt-6 max-w-3xl text-xl leading-relaxed text-blue-50">
        PrincipalAI helps organisations deploy language models and AI services in private cloud, dedicated server, or on-premise environments.
      </p>

      <a href="/contact" class="mt-8 inline-block rounded-md bg-blue-600 px-7 py-3 font-semibold text-white hover:bg-blue-700">
        Request a demonstration
      </a>
    </div>
  </section>

  <main>
    <section class="bg-white px-8 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">The problem</p>
          <h2 class="font-serif text-4xl font-bold leading-tight text-gray-900">
            Sensitive work needs more control than public AI tools can provide.
          </h2>
        </div>

        <div class="space-y-5 text-lg leading-relaxed text-gray-700">
          <p>
            Organisations often need AI capability for confidential documents, internal data, client material, and sensitive analytical workflows.
          </p>
          <p>
            Local and private model hosting allows organisations to use AI while retaining greater control over data flows, infrastructure, access, and operational settings.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 px-8 py-20">
      <div class="mx-auto max-w-7xl">
        <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">What it supports</p>
        <h2 class="max-w-4xl font-serif text-4xl font-bold leading-tight text-gray-900">
          Flexible AI deployment for controlled environments.
        </h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Private deployment</h3>
            <p class="mt-4 text-gray-700">
              Run AI services in approved infrastructure rather than relying only on public systems.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Model flexibility</h3>
            <p class="mt-4 text-gray-700">
              Select model configurations that match performance, cost, privacy, and workflow requirements.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Secure integration</h3>
            <p class="mt-4 text-gray-700">
              Connect AI models to documents, databases, dashboards, and analytical systems within controlled boundaries.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Operational control</h3>
            <p class="mt-4 text-gray-700">
              Manage access, workflows, review points, and deployment settings around organisational needs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#071f3f] px-8 py-20 text-white">
      <div class="mx-auto max-w-7xl text-center">
        <h2 class="mx-auto max-w-4xl font-serif text-4xl font-bold leading-tight">
          Build AI capability inside your own environment.
        </h2>
        <p class="mx-auto mt-5 max-w-3xl text-lg leading-relaxed text-blue-50">
          Talk to PrincipalAI about private model hosting, secure AI deployment, and controlled AI operations.
        </p>
        <a href="/contact" class="mt-8 inline-block rounded-md bg-blue-600 px-7 py-3 font-semibold text-white hover:bg-blue-700">
          Request a demonstration
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
