---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
---

<BaseLayout
  SEOTitle="Decision Assurance | PrincipalAI"
  SEODescription="AI-supported decision assurance for evidence, review, traceability, and defensible recommendations."
>
  <section class="bg-gradient-to-r from-[#071f3f] via-[#123f86] to-[#e8f4ff] px-8 py-24 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-blue-100">
        Decision Assurance
      </p>

      <h1 class="max-w-5xl font-serif text-5xl font-bold leading-tight sm:text-6xl">
        Make AI-supported decisions more defensible.
      </h1>

      <p class="mt-6 max-w-3xl text-xl leading-relaxed text-blue-50">
        PrincipalAI helps organisations strengthen confidence in AI-assisted analysis through evidence grounding, review workflows, traceability, and structured reporting.
      </p>

      <a href="/contact" class="mt-8 inline-block rounded-md bg-blue-600 px-7 py-3 font-semibold text-white hover:bg-blue-700">
        Request a demonstration
      </a>
    </div>
  </section>

  <main>
    <section class="bg-white px-8 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">The problem</p>
          <h2 class="font-serif text-4xl font-bold leading-tight text-gray-900">
            Decisions need more than fast answers.
          </h2>
        </div>

        <div class="space-y-5 text-lg leading-relaxed text-gray-700">
          <p>
            In high-value advisory, policy, infrastructure, energy, health, and regulatory settings, organisations need to understand the evidence behind recommendations.
          </p>
          <p>
            Decision assurance helps teams review AI-assisted outputs, test whether claims are supported, and document how evidence informs advice.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 px-8 py-20">
      <div class="mx-auto max-w-7xl">
        <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">What it supports</p>
        <h2 class="max-w-4xl font-serif text-4xl font-bold leading-tight text-gray-900">
          Assurance for evidence-heavy and judgement-intensive work.
        </h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Evidence grounding</h3>
            <p class="mt-4 text-gray-700">
              Link outputs to approved documents, datasets, references, and modelled evidence.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Traceability</h3>
            <p class="mt-4 text-gray-700">
              Make it easier to understand where information came from and how it was used.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Review workflows</h3>
            <p class="mt-4 text-gray-700">
              Embed structured review points before outputs are used in advice, reporting, or decisions.
            </p>
          </div>

          <div class="rounded-md bg-white p-7 shadow-sm ring-1 ring-gray-200">
            <h3 class="font-serif text-2xl font-bold text-gray-900">Defensible reporting</h3>
            <p class="mt-4 text-gray-700">
              Produce summaries that clearly identify assumptions, evidence, limitations, and implications.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white px-8 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">Example applications</p>
          <h2 class="font-serif text-4xl font-bold leading-tight text-gray-900">
            Built for decisions that need to withstand scrutiny.
          </h2>
        </div>

        <div class="grid gap-4 text-lg text-gray-700">
          <div class="rounded-md border border-gray-200 bg-gray-50 p-5">
            Assurance of policy advice, business cases, and investment recommendations.
          </div>
          <div class="rounded-md border border-gray-200 bg-gray-50 p-5">
            Review of AI-generated summaries, evidence tables, and analytical narratives.
          </div>
          <div class="rounded-md border border-gray-200 bg-gray-50 p-5">
            Documentation of assumptions, uncertainties, evidence sources, and limitations.
          </div>
          <div class="rounded-md border border-gray-200 bg-gray-50 p-5">
            Governance workflows for public-sector, regulatory, and technical advisory outputs.
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#071f3f] px-8 py-20 text-white">
      <div class="mx-auto max-w-7xl text-center">
        <h2 class="mx-auto max-w-4xl font-serif text-4xl font-bold leading-tight">
          Strengthen confidence in AI-supported decisions.
        </h2>
        <p class="mx-auto mt-5 max-w-3xl text-lg leading-relaxed text-blue-50">
          Talk to PrincipalAI about decision assurance, evidence traceability, and governed AI workflows.
        </p>
        <a href="/contact" class="mt-8 inline-block rounded-md bg-blue-600 px-7 py-3 font-semibold text-white hover:bg-blue-700">
          Request a demonstration
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
