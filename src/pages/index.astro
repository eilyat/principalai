---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import Resource_wide from "@/components/ResList_frontpage.astro";
import Publications_wide from "@/components/frontpage/Publications_wide.astro";
import Articles_wide from "@/components/frontpage/Articles_wide.astro";
import SectorTabs from "@/components/frontpage/Sector_tabs.astro";
import Herowaves from "@/components/frontpage/herowaves.astro";
---

<BaseLayout>
  <Fragment slot="SEO">
    <meta property="og:title" content="Principal AI - Intelligence built for decisions" />
    <meta property="og:description" content="AI systems for evidence, modelling, and decision intelligence." />
    <meta property="og:url" content="https://precai.com/" />
  </Fragment>
  <Herowaves />
<main>
  <!-- Capability strip -->
  <section class="bg-white border-b border-gray-200">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-0 px-8 py-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="border-gray-200 py-4 pr-8 lg:border-r">
        <div class="mb-4 text-blue-600">
          <svg class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
            <path d="M9 3h6v3h3v6h3v6h-3v3h-6v-3H9v3H3v-6h3V9H3V3h6v3Z" />
            <path d="M9 9h6v6H9Z" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900">Sovereign AI</h3>
        <p class="mt-3 text-base leading-relaxed text-gray-700">
          Secure, locally deployed AI that keeps your data and intellectual property under your control.
        </p>
      </div>

      <div class="border-gray-200 py-4 pr-8 pl-0 sm:pl-8 lg:border-r">
        <div class="mb-4 text-blue-600">
          <svg class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
            <path d="M4 19h16" />
            <path d="M6 16v-4" />
            <path d="M11 16V8" />
            <path d="M16 16V5" />
            <path d="M18 5l2 2-2 2" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900">Decision Intelligence</h3>
        <p class="mt-3 text-base leading-relaxed text-gray-700">
          Turn complex data and knowledge into actionable insight and recommendations.
        </p>
      </div>

      <div class="border-gray-200 py-4 pr-8 pl-0 sm:pl-8 lg:border-r">
        <div class="mb-4 text-blue-600">
          <svg class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="8" />
            <circle cx="12" cy="12" r="3" />
            <path d="M12 2v3" />
            <path d="M22 12h-3" />
            <path d="M12 22v-3" />
            <path d="M2 12h3" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900">Simulation & Forecasting</h3>
        <p class="mt-3 text-base leading-relaxed text-gray-700">
          Explore futures and test scenarios with advanced models and AI-powered simulation.
        </p>
      </div>

      <div class="py-4 pl-0 sm:pl-8">
        <div class="mb-4 text-blue-600">
          <svg class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
            <path d="M12 3l7 3v6c0 4.2-2.8 7.6-7 9-4.2-1.4-7-4.8-7-9V6l7-3Z" />
            <path d="M9 12l2 2 4-5" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900">Trusted Expertise</h3>
        <p class="mt-3 text-base leading-relaxed text-gray-700">
          Deep domain expertise across economics, infrastructure, energy, health, transport and more.
        </p>
      </div>
    </div>
  </section>

  <!-- Intelligence platforms -->
  <section class="bg-gradient-to-b from-blue-50 to-white px-8 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        <div>
          <p class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">
            Our solutions
          </p>
          <h2 class="max-w-lg font-serif text-4xl font-bold leading-tight text-gray-900 sm:text-5xl">
            Intelligence platforms built for impact.
          </h2>
        </div>

        <p class="max-w-2xl text-lg leading-relaxed text-gray-700 lg:pt-10">
          Our integrated suite of platforms helps organisations unlock the value of their data,
          automate knowledge work, and make better decisions.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-7 md:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-md bg-white p-8 shadow-sm ring-1 ring-gray-200 transition hover:-translate-y-1 hover:shadow-md">
          <div class="mb-6 text-blue-600">
            <svg class="h-11 w-11" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <circle cx="12" cy="5" r="2" />
              <circle cx="6" cy="17" r="2" />
              <circle cx="18" cy="17" r="2" />
              <path d="M12 7v4" />
              <path d="M12 11l-6 4" />
              <path d="M12 11l6 4" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-bold leading-tight text-gray-900">EconAI</h3>
          <p class="mt-4 text-base leading-relaxed text-gray-700">
            AI-powered research and policy intelligence for economic analysis, literature synthesis, and evidence extraction.
          </p>
          <a href="/solutions/econai" class="mt-7 inline-flex items-center font-semibold text-blue-600">
            Learn more <span class="ml-2">→</span>
          </a>
        </article>

        <article class="rounded-md bg-white p-8 shadow-sm ring-1 ring-gray-200 transition hover:-translate-y-1 hover:shadow-md">
          <div class="mb-6 text-emerald-600">
            <svg class="h-11 w-11" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <path d="M5 19V9h3v10H5Z" />
              <path d="M11 19V5h3v14h-3Z" />
              <path d="M17 19V2h3v17h-3Z" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-bold leading-tight text-gray-900">Cost Intelligence Platform</h3>
          <p class="mt-4 text-base leading-relaxed text-gray-700">
            Live cost forecasting and market intelligence powered by commodity prices, cost indices, and predictive analytics.
          </p>
          <a href="/solutions/cost-intelligence" class="mt-7 inline-flex items-center font-semibold text-blue-600">
            Learn more <span class="ml-2">→</span>
          </a>
        </article>

        <article class="rounded-md bg-white p-8 shadow-sm ring-1 ring-gray-200 transition hover:-translate-y-1 hover:shadow-md">
          <div class="mb-6 text-purple-600">
            <svg class="h-11 w-11" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <path d="M20.8 6.2a5.4 5.4 0 0 0-7.6 0L12 7.4l-1.2-1.2a5.4 5.4 0 0 0-7.6 7.6L12 22l8.8-8.2a5.4 5.4 0 0 0 0-7.6Z" />
              <path d="M7 12h3l1-2 2 5 1-3h3" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-bold leading-tight text-gray-900">Health Vulnerability Assessment Toolkit</h3>
          <p class="mt-4 text-base leading-relaxed text-gray-700">
            AI-supported climate and health intelligence for vulnerability assessment, adaptation pathways, and resilience.
          </p>
          <a href="/solutions/health-vulnerability" class="mt-7 inline-flex items-center font-semibold text-blue-600">
            Learn more <span class="ml-2">→</span>
          </a>
        </article>

        <article class="rounded-md bg-white p-8 shadow-sm ring-1 ring-gray-200 transition hover:-translate-y-1 hover:shadow-md">
          <div class="mb-6 text-orange-500">
            <svg class="h-11 w-11" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <path d="M12 2l8 4.5v9L12 20l-8-4.5v-9L12 2Z" />
              <path d="M12 11l8-4.5" />
              <path d="M12 11L4 6.5" />
              <path d="M12 11v9" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-bold leading-tight text-gray-900">AI Operations Platform</h3>
          <p class="mt-4 text-base leading-relaxed text-gray-700">
            Secure deployment and orchestration of AI models, simulations, and analytical workflows in your environment.
          </p>
          <a href="/solutions/ai-operations" class="mt-7 inline-flex items-center font-semibold text-blue-600">
            Learn more <span class="ml-2">→</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <div class="bg-gray-100 py-0">
    <Articles_wide />
  </div>
    <div class="py-4"></div>

    <span
      class="flex items-center w-full overflow-hidden font-serif italic py-4"
    >
      <span class="text-4xl px-6">
        Collaborative expertise across diverse industries</span
      >
      <span class="h-[2px] flex-1 bg-zinc-300"></span>
    </span>
    <div class="w-full my-6">
      <SectorTabs />
    </div>

    <div class="py-4"></div>

    <div class="p-2 bg-gray-100">
      <span
        class="flex items-center w-full overflow-hidden font-serif italic py-4"
      >
        <span class="text-4xl px-6">See our latest publications</span>
        <span class="h-[2px] flex-1 bg-zinc-300"></span>
      </span>
      <div class="px-6 pb-6">
        <Publications_wide />
      </div>
    </div>

    <div class="py-4"></div>

    <div class="p-2 bg-white">
      <span
        class="flex items-center w-full overflow-hidden font-serif italic py-4"
      >
        <span class="text-4xl px-6">Browse our resources</span>
        <span class="h-[2px] flex-1 bg-zinc-300"></span>
      </span>
      <Resource_wide />
    </div>
  </main>
</BaseLayout>
