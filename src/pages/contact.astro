---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import { Icon } from "astro-icon/components";
import ContactForm from "@/components/ui/ContactForm.astro";
---

<BaseLayout>
  <Fragment slot="SEO">
    <meta property="og:title" content="Contact | Principal Economics" />
    <meta
      property="og:url"
      content="https://principaleconomics.co.nz/contact"
    />
    <meta
      property="og:description"
      content="Contact Details, reach out through the usual channels."
    />
    <meta name="twitter:title" content="Contact | Principal Economics" />
    <meta
    name="twitter:description"
    content="Contact Details, reach out through the usual channels."
    />
    <link rel="canonical" href="https://principaleconomics.co.nz/contact" />
  </Fragment>
	<main class="px-6 max-w-screen-2xl items-center justify-start pl-4 mx-auto prose">
		<br />
    <div class="font-bold">
		<BreadCrumbsDefault />
    </div>
		<br />
		<div class="flex flex-col md:flex-row w-full">
      {/* Contact Info Section */}
      <div class="md:w-1/2 w-full flex items-center justify-center">
        <div class="space-y-6 md:space-y-8">
          <div class="max-w-md">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4" id="contact-details">Contact Details</h2>
            <p class="text-gray-600 mb-6">Reach out through any of these channels:</p>
            
            <div class="space-y-5 not-prose">
              {/* Phone */}
              <div class="flex items-start space-x-2" role="listitem">
                <Icon name="carbon:phone" size={25} class="block p-0 text-blue-600 duration-400 ease-in-out" aria-hidden="true" />
                <div>
                  <div class="text-lg font-medium text-gray-900">Phone</div>
                  <a href="tel:0064221564529" class="text-gray-600 hover:text-blue-600">+64 22 156 4529</a>
                </div>
              </div>
        
              {/* Email */}
              <div class="flex items-start space-x-2" role="listitem">
                <Icon name="carbon:email" size={25} class="block p-0 text-blue-600 duration-400 ease-in-out" aria-hidden="true" />
                <div>
                  <div class="text-lg font-medium text-gray-900">Email</div>
                  <a href="mailto:contact@precai.com" class="text-gray-600 hover:text-blue-600">contact@principaleconomics.com</a>
                </div>
              </div>
        
              {/* Address */}
              <div class="flex items-start space-x-2" role="listitem">
                <Icon name="carbon:pin" size={25} class="block p-0 text-blue-600 duration-400 ease-in-out" aria-hidden="true" />
                <div>
                  <div class="text-lg font-medium text-gray-900">Office Address</div>
                  <a href="https://maps.app.goo.gl/CpmRfMd1185F16Uu7"><div class="text-gray-600 hover:text-blue-600">
                    <address>
                      Level 14<br>
                      NZX Building<br>
                      Auckland<br>
                      New Zealand
                    </address>
                  </div>
                </a>
                </div>
              </div>
            </div>
          </div>


        </div>
      </div>

      {/* Contact Form Section */}
      <div class="md:w-1/2 w-full flex items-center justify-center">
        <div class="w-full max-w-2xl">
          <ContactForm />
        </div>
      </div>
    </div>
	</main>
</BaseLayout>
