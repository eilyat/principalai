---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import ShortHeader from "@/components/ui/ShortHeader.astro";
const { frontmatter } = Astro.props;

// Fetch all publications in the collection
import { getCollection } from "astro:content";
const industries = await getCollection("industries");

const filteredIndustries = industries.filter(industry => 
    frontmatter.tags?.some((tag: string) => industry.data.title === tag)
);


---

<BaseLayout SEOTitle="Publications">
    <Fragment slot="SEO">
        <meta property="type" content="website"/>
        <meta property="og:title" content={`${frontmatter.title} | Principal Economics`} />
        <meta
          property="og:url"
          content={`https://principaleconomics.co.nz${Astro.url.pathname}`}
        />
        <meta
          property="og:description"
          content={`Principal Economics: Your trusted experts in ${frontmatter.title}.`}
          />
        <meta 
          name="twitter:title" 
          content={`${frontmatter.title} | Principal Economics`}
          />
        <meta
          name="twitter:description"
          content={`Principal Economics: Your trusted experts in ${frontmatter.title}.`}
          />
        <link rel="canonical" href={`https://principaleconomics.co.nz${Astro.url.pathname}`} />    
      </Fragment>
	<ShortHeader title={frontmatter.title} subtitle={frontmatter.description}>		
	</ShortHeader>
	<main class="px-4 md:px-6 max-w-screen-2xl mx-auto">
		<div class="py-6"></div>
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
			<!-- Main Content -->
			<article class="lg:col-span-8 xl:col-span-9">		
				<div class="prose lg:prose-xl max-w-none">
					<slot />
				</div>
			</article>

<aside class="lg:col-span-4 xl:col-span-3 font-sans lg:px-5">
    <h3 class="text-xl lg:text-2xl font-bold text-gray-900 border-b pb-3 mb-4">
        Related Industries
    </h3>

    <ul class="space-y-5">
        {
            filteredIndustries.map((entry) => (
                <li>
                    <a class="flex items-center h-[90px] px-4 bg-gray-50 border-l-4 border-gray-200 rounded-md shadow-sm transition-all duration-200 hover:border-blue-500 hover:text-blue-700 hover:bg-gray-100 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" href=`/industries/${entry.slug}`>
                        <div class="flex flex-col justify-center">
                            <span class="font-medium text-gray-900 leading-tight text-lg">
                                {entry.data.title}
                            </span>
                            <span class="text-sm text-gray-500 line-clamp-2">
                                {entry.data.navDesc}
                            </span>
                        </div>
                    </a>
                </li>
            ))
        }
    </ul>
</aside>
		</div>
        
	</main>
    <br><br>
</BaseLayout>


