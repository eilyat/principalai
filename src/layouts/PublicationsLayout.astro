---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import ShortHeader from "@/components/ui/ShortHeader.astro";
const { frontmatter } = Astro.props;

import { getCollection } from "astro:content";
const team = await getCollection("team");

const authors = Array.isArray(frontmatter.authors) ? frontmatter.authors : []; 
const teamMemberMap = Object.fromEntries(team.map(member => [member.data.name.toLowerCase(), member.slug]));

const pubDate = new Date(frontmatter.pubDate); // Convert to Date object
const formattedDate = pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long" });

---

<BaseLayout SEOTitle="Publications">
	<Fragment slot="SEO">
		<meta name="citation_title" content={frontmatter.title}/>
		<meta name="citation_author" content={frontmatter.authors}/>
		<meta name="citation_publication" content={frontmatter.PubDate}/>
		<meta name="citation_pdf_url" content={frontmatter.downloadPdf} />
	</Fragment>
	<ShortHeader title={frontmatter.title} subtitle={frontmatter.tagline}>
		<p class="text-2xl text-white font-bold pt-2" >{formattedDate}</p>
	</ShortHeader>
	<main class="px-4 md:px-6 max-w-screen-2xl mx-auto">
			
		<div class="py-6">
			<!-- <BreadCrumbsDefault /> -->
		</div>
		
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
			<!-- Main Content -->
			<article class="lg:col-span-8 xl:col-span-9">
				<!-- <header class="mb-8">
					<h1 class="text-4xl font-bold text-gray-900 mb-4">{frontmatter.title}</h1>
					<p class="text-lg text-gray-600">Published on {formattedDate}</p>
				</header> -->
				
				<div class="prose lg:prose-xl max-w-none">
					<slot />
				</div>
			</article>

			<!-- Publication Details Sidebar -->
			<aside class="lg:col-span-4 xl:col-span-3 font-sans">
				<div class="sticky top-6 bg-gray-50 rounded-md shadow-sm p-6 border border-gray-200">
					<h2 class="text-2xl font-bold text-gray-900 mb-4  font-sans">Publication Details</h2>
					<dl class="space-y-4">
						<div>
							<dt class="font-semibold text-gray-700">Authors</dt>
							<dd class="mt-1 text-gray-600">
								{authors.map((author, index) => {
									const authorSlug = teamMemberMap[author.toLowerCase()];
									return (
										<span>
											{authorSlug ? (
												<a href={`/team/${authorSlug}`} class="text-blue-600 hover:underline">{author}</a>
											) : (
												<span>{author}</span>
											)}
											{index < authors.length - 1 ? ', ' : ''}
										</span>
									);
								})}
							</dd>
						</div>

						<div>
							<dt class="font-semibold text-gray-700">Published</dt>
							<dd class="mt-1 text-gray-600">{formattedDate}</dd>
						</div>

						<div>
							<dt class="font-semibold text-gray-700">Contact</dt>
							<dd class="mt-1 text-gray-600">
								<a href="mailto:eilya@principaleconomics.com" class="text-blue-600 hover:underline">eilya@principaleconomics.com</a>
							</dd>
						</div>

						<div>
							<dt class="font-semibold text-gray-700">Download</dt>
							<dd class="mt-1">
								<a href={frontmatter.downloadPdf} class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-sm hover:bg-blue-700 transition-colors">
									<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
									</svg>
									PDF Document
								</a>
							</dd>
						</div>
					</dl>
				</div>
			</aside>
		</div>
	</main>
</BaseLayout>