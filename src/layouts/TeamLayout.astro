---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import TeamCardDetails from "@/components/ui/TeamCardDetails.astro";
import PCard from "@/components/ui/PCard.astro";
import ScrollCards from "@/components/ui/ScrollCards.astro";
import SectionBreakHR from "@/components/ui/SectionBreakHR.astro";
import { Icon } from "astro-icon/components";


const { frontmatter } = Astro.props;

// Fetch all publications in the collection
import { getCollection } from "astro:content";
const publications = await getCollection("publications");
const articles = await getCollection("articles");
const resources = await getCollection("resources");

// Combine all collections into a single array
const allInsights = [
  ...publications.map((pub) => ({ ...pub, type: "publications" })),
  ...articles.map((art) => ({ ...art, type: "articles" })),
  ...resources.map((res) => ({ ...res, type: "resources" })),
];

// Ensure all insights have a valid pubDate before sorting
const sortedInsights = allInsights
  .filter((insight) => insight?.data?.pubDate) // Remove items without a valid date
  .sort((a, b) => {
    const dateA = new Date(a.data.pubDate || 0).getTime(); // Default to 0 if missing
    const dateB = new Date(b.data.pubDate || 0).getTime();
    return dateB - dateA; // Sort in descending order (most recent first)
  });

// Ensure authors exist before filtering
const filteredInsights = sortedInsights.filter(
  (insight) =>
    Array.isArray(insight?.data?.authors) &&
    insight.data.authors.includes(frontmatter.name),
);
---

<BaseLayout SEOTitle="Publications">
  <Fragment slot="SEO">
    <meta property="type" content="website"/>
    <meta property="og:title" content={`${frontmatter.name} | Principal Economics`} />
    <meta
    property="og:url"
    content={`https://principaleconomics.co.nz${Astro.url.pathname}`}
  />
    <meta
      property="og:description"
      content={`Learn more about ${frontmatter.name}, ${frontmatter.role} at Principal Economics.`}
      />
    <meta name="twitter:title" content={`${frontmatter.name} | Principal Economics`} />
    <meta
    name="twitter:description"
    content={`Learn more about ${frontmatter.name}, ${frontmatter.role} at Principal Economics.`}
    />
    <link rel="canonical" href={`https://principaleconomics.co.nz${Astro.url.pathname}`} />
  </Fragment>
  <main class="px-6 max-w-screen-2xl mx-auto">
    <br />
    <BreadCrumbsDefault />
    <br />

    <!-- Content Section -->
    <div class="pt-8">
      <!-- Headings for small screens (visible on small screens only) -->
      <div class="sm:hidden mb-6">
        <h1 class="text-6xl font-medium pb-4">{frontmatter.name}</h1>
        <h2 class="text-4xl font-medium pb-6">{frontmatter.role}</h2>
      </div>

      <!-- Aside with TeamCardDetails (Image Container) -->
      <div
        class="team-image-container float-left mb-8 mr-16 items-stretch w-full sm:w-auto sm:max-w-xs"
      >
        <TeamCardDetails
          photo={frontmatter.photo}
          alt={frontmatter.alt}
          location={frontmatter.location}
          email={frontmatter.email}
          qualification={frontmatter.qualification}
        />
      </div>

      <!-- Main content -->
      <main class="pt-16">
        <!-- Headings for larger screens (visible on medium and up screens only) -->
        <div class="hidden sm:block">
          <h1 class="text-6xl font-medium pb-4">{frontmatter.name}</h1>
          <h2 class="text-4xl font-medium pb-4">{frontmatter.role}</h2>

          <div class="mt-0 pb-6 inline-flex justify-start items-center transition-colors group-hover:text-blue-600 duration-500">
            {frontmatter.phone && (
              <a href={`tel:${frontmatter.phone}`} target="_blank" rel="noopener noreferrer" class="flex-shrink-0 pr-1">
                <Icon name="carbon:phone" size={32} class="block p-0 text-gray-700 transition hover:opacity-75" />
              </a>
              )}
            {frontmatter.email && (
              <a href={`mailto:${frontmatter.email}`} target="_blank" rel="noopener noreferrer" class="flex-shrink-0 pr-1">
                <Icon name="carbon:email" size={33} class="block p-0 text-gray-700 transition hover:opacity-75" />
              </a>
              )}
            {frontmatter.linkedin && (
            <a href={frontmatter.linkedin} target="_blank" rel="noopener noreferrer" class="flex-shrink-0 pr-1">
              <Icon name="carbon:logo-linkedin" size={33} class="block p-0 text-gray-700 transition hover:opacity-75" />
            </a>
            )}
            {frontmatter.orcid && (
              <a href={frontmatter.orcid} target="_blank" rel="noopener noreferrer" class="flex-shrink-0 pr-1">
                <Icon name="academicons:orcid" size={26} class="block p-0 text-gray-700 transition hover:opacity-75" />
              </a>
              )}
            {frontmatter.ssrn && (
              <a href={frontmatter.ssrn} target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
                <Icon name="academicons:ssrn" size={33} class="block p-0 text-gray-700 transition hover:opacity-75" />
              </a>
              )}
          </div>


        </div>

        <section class="prose max-w-none prose-lg prose-headings:-mt-4">
          <slot />
        </section>

        {filteredInsights.length > 0 && (
          <>
            <SectionBreakHR>Recent Publications</SectionBreakHR>
            <ScrollCards>
              {filteredInsights.map((entry, index) => (
                <div class="w-full">
                  <PCard
                    title={entry.data.title}
                    date={
                      entry.data.pubDate
                        ? new Date(entry.data.pubDate).toLocaleDateString(
                            undefined,
                            {
                              year: "numeric",
                              month: "long",
                              timeZone: "UTC",
                            }
                          )
                        : "Unknown Date"
                    }
                    category={String(entry.data.type)}
                    imgSrc={entry.data.cardImage}
                    imgAlt={entry.data.title}
                    link={`/${entry.type || "default"}/${entry.slug || "default"}`}
                    class="h-full"
                  />
                </div>
              ))}
            </ScrollCards>
          </>
        )}
      </main>
    </div>
  </main>
  <br>
</BaseLayout>
