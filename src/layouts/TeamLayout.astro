---
import "@/styles/global.css";
import BaseLayout from "@/components/BaseLayout.astro";
import BreadCrumbsDefault from "@/components/ui/BreadCrumbsDefault.astro";
import TeamCardDetails from "@/components/ui/TeamCardDetails.astro";
import PCard from "@/components/ui/PCard.astro";
import ScrollCards from "@/components/ui/ScrollCards.astro";
import SectionBreakHR from "@/components/ui/SectionBreakHR.astro";

const { frontmatter } = Astro.props;

// Fetch all publications in the collection
import { getCollection } from "astro:content";
const publications = await getCollection("publications");
const articles = await getCollection("articles");
const resources = await getCollection("resources");

// Combine all collections into a single array
const allInsights = [
  ...publications.map((pub) => ({ ...pub, type: "publications" })),
  ...articles.map((art) => ({ ...art, type: "articles" })),
  ...resources.map((res) => ({ ...res, type: "resources" })),
];

// Ensure all insights have a valid pubDate before sorting
const sortedInsights = allInsights
  .filter((insight) => insight?.data?.pubDate) // Remove items without a valid date
  .sort((a, b) => {
    const dateA = new Date(a.data.pubDate || 0).getTime(); // Default to 0 if missing
    const dateB = new Date(b.data.pubDate || 0).getTime();
    return dateB - dateA; // Sort in descending order (most recent first)
  });

// Ensure authors exist before filtering
const filteredInsights = sortedInsights.filter(
  (insight) =>
    Array.isArray(insight?.data?.authors) &&
    insight.data.authors.includes(frontmatter.name)
);
---

<BaseLayout SEOTitle="Publications">
  <Fragment slot="SEO">
    <meta name="title" content={frontmatter.name} />
  </Fragment>

  <main class="px-6 max-w-screen-2xl mx-auto">
    <br />
    <BreadCrumbsDefault />
    <br />

    <!-- Content Section -->
    <div class="pt-8">
      <!-- Headings for small screens (visible on small screens only) -->
      <div class="sm:hidden mb-6">
        <h1 class="text-6xl font-medium pb-4">{frontmatter.name}</h1>
        <h2 class="text-4xl font-medium pb-6">{frontmatter.role}</h2>
      </div>

      <!-- Aside with TeamCardDetails (Image Container) -->
      <div
        class="team-image-container float-left mb-8 mr-16 items-stretch w-full sm:w-auto sm:max-w-xs"
      >
        <TeamCardDetails
          photo={frontmatter.photo}
          alt={frontmatter.alt}
          location={frontmatter.location}
          email={frontmatter.email}
          qualification={frontmatter.qualification}
        />
      </div>

      <!-- Main content -->
      <main class="pt-16">
        <!-- Headings for larger screens (visible on medium and up screens only) -->
        <div class="hidden sm:block">
          <h1 class="text-6xl font-medium pb-4">{frontmatter.name}</h1>
          <h2 class="text-4xl font-medium pb-6">{frontmatter.role}</h2>
        </div>

        <section class="prose max-w-none prose-lg prose-headings:-mt-4">
          <slot />
        </section>

        <SectionBreakHR>Recent Publications</SectionBreakHR>
        <ScrollCards>
          {
            filteredInsights.map((entry, index) => (
              <div class="w-full">
                <PCard
                  title={entry.data.title}
                  date={
                    entry.data.pubDate
                      ? new Date(entry.data.pubDate).toLocaleDateString(
                          undefined,
                          {
                            dateStyle: "medium",
                            timeZone: "UTC",
                          }
                        )
                      : "Unknown Date"
                  }
                  category={String(entry.data.type)}
                  imgSrc={entry.data.cardImage}
                  imgAlt={entry.data.title}
                  link={`/${entry.type || "default"}/${entry.slug || "default"}`}
                  class="h-full"
                />
              </div>
            ))
          }
        </ScrollCards>
      </main>
    </div>
  </main>
</BaseLayout>
