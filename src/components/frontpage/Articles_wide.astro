---
import "@/styles/global.css";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Lighthouse from "@/images/lighthouse.png";
// Fetch and process data
const articles = await getCollection("articles");
const team = await getCollection("team");

// Sort publications
const sortedArticles = [...articles]
  .filter((pub) => pub?.data?.pubDate)
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  )
  .slice(0, 2);

const teamMap = new Map(
  team.map((member) => [member.data.name.toLowerCase(), member.slug])
);
---

{
  sortedArticles.map((entry, index) => {
    const isEven = index % 2 === 0;
    return (
      <article class="group" id={`/articles/${index}`}>
        <div
          class={`flex flex-col md:flex-row items-center ${isEven ? "" : "md:flex-row-reverse"}`}
        >
          {/* Content */}
          <div class="w-full md:w-1/2 p-8 lg:p-12 space-y-1">
            {" "}
            {/* Added padding here */}
            <div class="space-y-3">
              <a
                href={`/articles/${entry.slug}`}
                class="text-3xl font-bold text-gray-900 hover:text-blue-600 transition-colors"
              >
                {entry.data.title}
              </a>
              <div class="flex flex-wrap gap-2 text-sm font-medium">
                <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full">
                  {entry.data.type}
                </span>
                <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                  {entry.data.pubDate
                    ? new Date(entry.data.pubDate).toLocaleDateString(
                        undefined,
                        {
                          month: "long",
                          year: "numeric",
                          timeZone: "UTC",
                        }
                      )
                    : "Unknown Date"}
                </span>
              </div>

              <p class="text-gray-600 font-medium space-y-2">
                Authors:{" "}
                {entry.data.authors?.map((author, authorIndex) => {
                  const normalizedName = author.trim().toLowerCase();
                  const isTeamMember = teamMap.has(normalizedName);
                  const isLast = authorIndex === entry.data.authors.length - 1;

                  return (
                    <>
                      {isTeamMember ? (
                        <a
                          href={`about/team/${teamMap.get(normalizedName)}`}
                          class="text-blue-600 hover:underline"
                        >
                          {author}
                        </a>
                      ) : (
                        <span class="text-gray-700">{author}</span>
                      )}
                      {!isLast && ", "}
                    </>
                  );
                }) ?? <span>No authors listed</span>}
              </p>
            </div>
            <p class="text-xl text-gray-700 leading-relaxed line-clamp-6">
              {entry.body}
            </p>
            <a
              href={`/articles/${entry.slug}`}
              class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium transition-colors space-y-2"
            >
              Read more
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 ml-1"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
            </a>
          </div>

          {/* Image Card */}
          <div class="w-full md:w-1/2">
            <a href={`/articles/${entry.slug}`}>
              <Image
                src={entry.data.cardImage || Lighthouse}
                alt={entry.data.title}
                class="w-full h-[441px] object-cover"
              />
            </a>
          </div>
        </div>
      </article>
    );
  })
}
