---
// FeatureBox.astro
const { number, description, class: customClass = '' , href} = Astro.props;
---

<button class={`flex items-center gap-4 w-full md:w-1/2 lg:w-1/4 pt-0 pb-0 pr-2 ${customClass}`}>
    <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-accent text-black">
      <span class="text-blue-500 font-bold md:text-2xl leading-none">{number}</span>
    </span>
    <div class = "flex justify-start items-center">
      <p class="text-sm text-muted-foreground text-left md:text-base mb-0">
      </p>
      <a href={`${href}`}
      class="text-sm text-muted-foreground text-left md:text-base mb-0 hover:text-blue-800 hover:underline focus:outline-none">
             {description}
   </a>
    </div>
  </button>

