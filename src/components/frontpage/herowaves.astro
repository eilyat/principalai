    <script>
      document.addEventListener("astro:after-swap", () => {
  console.log("Reinitializing animated lines script...");
  initAnimatedLines();
});

function initAnimatedLines() {
      const svgEl = document.getElementById('animated-lines') as SVGSVGElement | null;

const randomRange = (min: number, max: number): number => {
  return Math.floor(Math.random() * (max - min + 1)) + min;
};

const numberOfLines = 50;
const lineDataArr: Array<{
  counter: number;
  startX: number;
  startY: number;
  endX: number;
  endY: number;
  sin: number;
  cos: number;
  pointX: number;
  centerX: number;
  centerY: number;
}> = [];

const createPathString = (): string => {
  let completedPath = '';
  const comma = ',';
  const ampl = 50; // pixel range from 0, aka how deeply they bend

  for (let i = 0; i < numberOfLines; i++) {
    const path = lineDataArr[i];
    if (!path) continue;

    const current = {
      x: ampl * Math.sin(path.counter / path.sin),
      y: ampl * Math.cos(path.counter / path.cos),
    };

    const newPathSection =
      `M${path.startX}${comma}${path.startY} ` +
      `Q${path.pointX}${comma}${(current.y * 1.5).toFixed(10)} ` +
      `${((current.x) / 10 + path.centerX).toFixed(3)}${comma}` +
      `${((current.y) / 5 + path.centerY).toFixed(3)} ` +
      `T${path.endX}${comma}${path.endY}`;
    
    path.counter++;
    completedPath += newPathSection;
  }

  return completedPath;
};

const createLines = (): void => {
  if (!svgEl) return;

  const newPathEl = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  const minSpeed = 300;
  const maxSpeed = 350;

  for (let i = 0; i < numberOfLines; i++) {
    const lineDataObj = {
      counter: randomRange(1, 500),
      startX: randomRange(-5, -30),
      startY: randomRange(5, 40),
      endX: randomRange(200, 220),
      endY: randomRange(120, 140),
      sin: randomRange(minSpeed, maxSpeed),
      cos: randomRange(minSpeed, maxSpeed),
      pointX: randomRange(30, 55),
      centerX: randomRange(90, 120),
      centerY: randomRange(60, 70),
    };

    lineDataArr.push(lineDataObj);
  }

  const animLoop = (): void => {
    newPathEl.setAttribute('d', createPathString());
    requestAnimationFrame(animLoop);
  };

  newPathEl.setAttribute('fill', 'none');
  newPathEl.setAttribute('stroke', 'white');
  newPathEl.setAttribute('stroke-width', '1.4');
  newPathEl.setAttribute('vector-effect', 'non-scaling-stroke');
  svgEl.appendChild(newPathEl);
  animLoop();
};

createLines();}

// Run script on initial page load
initAnimatedLines();


    </script>