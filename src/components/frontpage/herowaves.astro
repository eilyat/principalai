  <!-- SVG Background Animation -->
  <svg class="absolute top-0 left-0 z-0 opacity-30 overflow-clip pointer-events-none" width="4000" height="5000"
  id="animated-lines" viewBox="100 -20 460 830"></svg>  

  <!-- Content Wrapper (Vertically Centered) -->
  <div class="relative z-10 text-gray-800 flex-1 flex items-center justify-center sm:justify-end sm:px-8 h-full w-full">
    <!-- Right Column -->
    <div class="text-gray-800 text-left sm:text-left max-w-lg w-full px-4 sm:px-0 sm:mr-12 lg:mr-36">
