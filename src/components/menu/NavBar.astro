---
export const partial = true;
// import Industries from "./industries.astro";
import SearchWidget from "./SearchWidget.astro";
import NavCluser from "./NavCluster.astro";
---

<nav
id = "nav"
class="nav relative text-gray-900 w-full py-2 h-14 border-b-2 shadow-md">
  
  <div class="flex flex-row max-w-screen-2xl mx-auto py-0 h-full items-center">
    <div class="lg:px-6 text-xl text-blue-600 font-bold border-r-2 h-full items-center flex px-2 justify-start">
      Principal Economics
    </div>
      <NavCluser/>
      <div class="flex flex-row ml-auto justify-end items-center h-full">
        <SearchWidget />
      </div>
    </div>
</nav>

<style>
  .toggleable > label:after {
    content: "\25BC";
    font-size: 10px;
    padding-left: 6px;
    position: relative;
    top: -1px;
  }

  .toggle-input {
    display: none;
  }

</style>

