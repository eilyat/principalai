---
import { Icon } from "astro-icon/components";

const technology = [
  {
    title: "Sovereign AI",
    desc: "Private AI systems that keep data, models, and workflows under organisational control.",
    href: "/technology/sovereign-ai",
  },
  {
    title: "Private Model Hosting",
    desc: "Deploy language models and AI services in controlled environments.",
    href: "/technology/private-model-hosting",
  },
  {
    title: "Knowledge Systems",
    desc: "Connect AI to reports, documents, datasets, and institutional knowledge.",
    href: "/technology/knowledge-systems",
  },
  {
    title: "Large Language Models",
    desc: "Apply LLMs to evidence retrieval, analysis, reporting, and decision support.",
    href: "/technology/large-language-models",
  },
  {
    title: "Economic Modelling",
    desc: "Combine AI with Principal Economics’ modelling capability and IP.",
    href: "/technology/economic-modelling",
  },
  {
    title: "Simulation and Forecasting",
    desc: "Explore future scenarios, test assumptions, and interpret modelled outcomes.",
    href: "/technology/simulation-forecasting",
  },
  {
    title: "Geospatial Intelligence",
    desc: "Use spatial data and AI-assisted interpretation for place-based decisions.",
    href: "/technology/geospatial-intelligence",
  },
  {
    title: "Digital Twins",
    desc: "Interactive decision environments for systems, assets, places, and scenarios.",
    href: "/technology/digital-twins",
  },
  {
    title: "Responsible AI",
    desc: "Support transparency, assurance, privacy, and professional judgement.",
    href: "/technology/responsible-ai",
  },
];
---

<div class="w-full bg-white px-7">
  <div class="mx-auto grid max-w-screen-2xl grid-cols-12 gap-0">
    <div class="hidden bg-white p-6 sm:block lg:col-span-2">
      <div class="text-3xl font-bold">
        Technology
        <a href="/technology">
          <div class="group flex place-items-center gap-2 pt-1 text-base font-semibold text-blue-600 hover:underline hover:underline-offset-8">
            See more details
            <Icon name="carbon:arrow-right" class="size-6 transition-transform duration-200 group-hover:translate-x-2" />
          </div>
        </a>
      </div>
    </div>

    <div class="col-span-12 bg-white p-4 lg:col-span-10">
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
        {
          technology.map((item) => (
            <li class="text-gray-800">
              <a
                class="block min-h-[90px] w-full border-l-2 border-gray-300 bg-white py-2 pl-4 text-left text-gray-600 hover:border-l-4 hover:border-blue-500 hover:bg-gray-100 hover:text-blue-700 hover:shadow-sm"
                href={item.href}
              >
                <div class="flex h-full flex-col justify-center">
                  <span class="text-lg font-semibold leading-tight">{item.title}</span>
                  <span class="mt-1 text-sm text-gray-500">{item.desc}</span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="block sm:hidden">
        <br />
        <a href="/technology">
          <div class="group flex place-items-center gap-2 pt-1 text-base font-semibold text-blue-600 hover:underline hover:underline-offset-8">
            See more details
            <Icon name="carbon:arrow-right" class="size-6 transition-transform duration-200 group-hover:translate-x-2" />
          </div>
        </a>
      </div>
    </div>
  </div>
</div>
