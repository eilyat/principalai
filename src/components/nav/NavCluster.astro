---
import Solutions from "@/components/nav/SolutionsMenu.astro";
import Industries from "@/components/nav/IndustriesMenu.astro";
import Technology from "@/components/nav/TechnologyMenu.astro";
import Insights from "@/components/nav/InsightsMenu.astro";
import About from "@/components/nav/AboutMenu.astro";
import Contact from "@/components/nav/ContactMenu.astro";
---

<div
  x-data="{
    open: false,
    navigationMenu: '',
    menuItems: [
      { name: 'solutions',  label: 'Solutions' },
      { name: 'industries', label: 'Industries' },
      { name: 'technology', label: 'Technology' },
      { name: 'insights',   label: 'Insights' },
      { name: 'about',      label: 'About' },
      { name: 'contact',    label: 'Contact' }
    ],
    toggleMenu(menu) {
      this.navigationMenu = this.navigationMenu === menu ? '' : menu;
      this.open = this.navigationMenu ? true : false;
    },
    navigationMenuClose() {
      this.navigationMenu = '';
      this.open = false;
    }
  }"
  @keydown.esc.window="open = false"
  @click.outside="open = false"
  x-ref="nav"
>
  <div class="place-items-start items-center h-full">
    <ul class="flex flex-row h-full">
      <template x-for="item in menuItems" :key="item.name">
        <li class="toggleable hover:bg-slate-100 hover:text-black h-full py-2">
          <button
            @click="toggleMenu(item.name)"
            @keydown.space.prevent="toggleMenu(item.name)"
            @keydown.enter.prevent="toggleMenu(item.name)"
            @keydown.down.prevent="toggleMenu(item.name)"
            :aria-label="item.label + '-menu'"
            class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
          >
            <span x-text="item.label" class="whitespace-nowrap"></span>
            <span class="relative w-4 h-4 ml-2 shrink-0">
              <svg
                class="absolute w-full h-full transition-transform duration-300"
                :class="navigationMenu === item.name ? 'rotate-180' : 'rotate-0'"
                aria-hidden="true"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                fill="none"
              >
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="sr-only">
                <span x-text="navigationMenu === item.name ? 'Collapse' : 'Expand'"></span> menu
              </span>
            </span>
          </button>
        </li>
      </template>
    </ul>
  </div>

  <div
    x-show="open"
    x-collapse
    x-trap.noautofocus="open"
    x-cloak
    x-anchor.no-style="$refs.nav"
    x-bind:style="{ position: 'absolute', top: $anchor.y, left: '0px' }"
    @keydown.down.prevent="$focus.wrap().next()"
    @keydown.up.prevent="$focus.wrap().previous()"
    class="absolute shadow-md max-w-full w-full z-50 left-0"
  >
    <div>
      <template x-if="navigationMenu === 'solutions'">
        <Solutions />
      </template>

      <template x-if="navigationMenu === 'industries'">
        <Industries />
      </template>

      <template x-if="navigationMenu === 'technology'">
        <Technology />
      </template>

      <template x-if="navigationMenu === 'insights'">
        <Insights />
      </template>

      <template x-if="navigationMenu === 'about'">
        <About />
      </template>

      <template x-if="navigationMenu === 'contact'">
        <Contact />
      </template>
    </div>
  </div>
</div>

<style>
  [x-cloak] {
    display: none;
  }
</style>
