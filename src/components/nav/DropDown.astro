---
const {title, aria} = Astro.props;
---

<div
x-data="{ isOpened: false, openedWithKeyboard: false }" @keydown.esc.window="isOpened = false, openedWithKeyboard = false"            
class="toggleable hover:bg-blue-800 hover:text-white"
>

    <!-- Label -->
    <button
    x-ref="button"
        @click.prevent="isOpened = !isOpened; console.log('Dropdown opened:', isOpened)"                 
        @keydown.space.prevent="openedWithKeyboard = true" 
        @keydown.enter.prevent="openedWithKeyboard = true" 
        @keydown.down.prevent="openedWithKeyboard = true" 
    aria-controls={aria}
    class="button flex flex-row cursor-pointer px-5 text-lg items-center h-full"
    >
      {title}
    </button>

    <!-- Panel -->
    <div
    x-cloak 
    x-show="isOpened || openedWithKeyboard" 
    x-collapse
    x-trap="openedWithKeyboard" 
    x-anchor.no-style="document.getElementById('nav')"
    x-bind:style="{ position: 'absolute', top: $anchor.y+'px'}"
    x-bind:class="!isOpened || !openedWithKeyboard ? 'z-40'"
    @click.outside="isOpened = false, openedWithKeyboard = false" 
    @keydown.down.prevent="$focus.wrap().next()" 
    @keydown.up.prevent="$focus.wrap().previous()" 
        id={aria}
        style="display: none;"
        class="absolute left-0 rounded-md shadow-md max-w-full w-full sm:flex-col z-50"
    >
    <slot />
    </div>
</div>


    <style>
        [x-cloak] { display: none; }
    
    </style>

<!-- 
x-transition:enter="ease-out duration-300 transform"
x-transition:enter-start="opacity-0"
x-transition:enter-end="opacity-100" 
x-transition:leave="transition ease-out duration-300"
x-transition:leave-start="opacity-100"
x-transition:leave-end="opacity-0" 
-->