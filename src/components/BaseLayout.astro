---
import NavBar from "@/components/nav/NavBar.astro";
import Footer from "@/components/Footer.astro";
// import "@/styles/global.css";
import { ViewTransitions } from "astro:transitions";
const { SEOTitle } = Astro.props;

---

<!doctype html>
<html lang="en">
  <head>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Raleway:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <meta charset="UTF-8" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Principal Economics" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    
    <slot name="SEO"/>
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Open Graph Meta Tags -->
    
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    
    <link rel="dns-prefetch" href="//cdnjs.cloudflare.com" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script>
      (window as any).pagefindOptions = {
        processResult: (result) => {
          result.url = result.url.replace(/\/#/, '#');
          return result;
        }
      };
    </script>
    <ViewTransitions />
     
  </head>
  <body>
    <NavBar />
      <slot />
    <Footer />
  </body>
</html>
