---
const year = new Date().getFullYear();
---

<footer class="bg-[#071f3f] text-white">
  <div class="mx-auto max-w-screen-2xl px-8 py-14">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <a href="/" class="inline-block">
          <img
            src="/principalai-logo.png"
            alt="PrincipalAI"
            class="h-12 w-auto"
          />
        </a>

        <p class="mt-5 max-w-md text-base leading-relaxed text-blue-100">
          PrincipalAI builds secure AI systems that turn evidence, models, and expertise into practical decision intelligence.
        </p>

        <p class="mt-5 text-sm text-blue-200">
          A Principal Economics company.
        </p>
      </div>

      <div>
        <h3 class="font-serif text-xl font-bold">Solutions</h3>
        <ul class="mt-4 space-y-3 text-sm text-blue-100">
          <li><a class="hover:text-white" href="/solutions/econai">EconAI</a></li>
          <li><a class="hover:text-white" href="/solutions/cost-intelligence">Cost Intelligence Platform</a></li>
          <li><a class="hover:text-white" href="/solutions/health-vulnerability">Health Adaptation Advisor</a></li>
          <li><a class="hover:text-white" href="/solutions/ai-operations">AI Operations Platform</a></li>
          <li><a class="hover:text-white" href="/solutions/decision-intelligence">Decision Intelligence Platform</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-serif text-xl font-bold">Technology</h3>
        <ul class="mt-4 space-y-3 text-sm text-blue-100">
          <li><a class="hover:text-white" href="/technology/sovereign-ai">Sovereign AI</a></li>
          <li><a class="hover:text-white" href="/technology/knowledge-systems">Knowledge Systems</a></li>
          <li><a class="hover:text-white" href="/technology/economic-modelling">Economic Modelling</a></li>
          <li><a class="hover:text-white" href="/technology/simulation-forecasting">Simulation and Forecasting</a></li>
          <li><a class="hover:text-white" href="/technology/geospatial-intelligence">Geospatial Intelligence</a></li>
          <li><a class="hover:text-white" href="/technology/responsible-ai">Responsible AI</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-serif text-xl font-bold">Contact</h3>
        <ul class="mt-4 space-y-3 text-sm text-blue-100">
          <li><a class="hover:text-white" href="/contact">Contact us</a></li>
          <li><a class="hover:text-white" href="mailto:info@principalai.com">info@principalai.com</a></li>
          <li><a class="hover:text-white" href="https://principaleconomics.com">Principal Economics</a></li>
          <li><a class="hover:text-white" href="/sitemap-index.xml">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-blue-800 pt-6 text-sm text-blue-200 md:flex md:items-center md:justify-between">
      <p>© {year} PrincipalAI. All rights reserved.</p>
      <p class="mt-3 md:mt-0">
        Intelligence built for decisions.
      </p>
    </div>
  </div>
</footer>
