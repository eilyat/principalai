---
const {
  entries = [],
  listTitle = "Articles",
  basePath = "/publications",
  categoryLabel = "Publication",
  itemsPerPage = 2
} = Astro.props;

const sortedEntriesJSON = JSON.stringify(entries);
---

<div class="flex flex-col md:flex-row gap-6">
  <!-- Left Column (Title) -->
  <div class="w-full md:w-1/3 lg:w-1/4 md:block">
    <h2 class="text-5xl font-bold">{listTitle}</h2>
  </div>

  <!-- Right Column (Content) -->
  <div
    class="w-full md:w-2/3 lg:w-3/4 space-y-6"
    x-data="paginationComponent()"
    x-init="initPublications($refs.jsonData.textContent, $el.dataset.itemsPerPage)"
    data-items-per-page={itemsPerPage}
  >
    <!-- Hidden JSON Data -->
    <div x-ref="jsonData" class="hidden">
      {sortedEntriesJSON}
    </div>

    <!-- Entries List -->
    <div class="text-gray-700">
      <template x-for="entry in paginatedPublications" :key="entry.slug">
        <article class="group p-4 bg-white shadow-sm rounded-xl hover:bg-gray-50 transition">
          <div class="space-y-3">
            <a
              :href="`${basePath}/${entry.slug}`"
              class="text-2xl font-bold text-gray-900 hover:text-blue-600 transition"
            >
              <span x-text="entry.data.title"></span>
            </a>

            <div class="flex flex-wrap gap-2 text-sm font-medium">
              <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full">
                {categoryLabel}
              </span>
              <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                <span x-text="new Date(entry.data.pubDate).toLocaleDateString(undefined, { year: 'numeric', month: 'long', timeZone: 'UTC' })"></span>
              </span>
            </div>

            <p class="text-gray-600 font-medium">
              Authors: <span
                class="text-gray-800"
                x-text="Array.isArray(entry.data.authors) ? entry.data.authors.join(', ') : 'Unknown Author'"
              ></span>
            </p>

            <p class="text-gray-700 leading-relaxed line-clamp-3" x-text="entry.body"></p>

            <a
              :href="`{basePath}/${entry.slug}`"
              class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium transition"
            >
              Read more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </a>
          </div>
        </article>
      </template>
    </div>

    <!-- Pagination Controls -->
    <div class="flex justify-center space-x-2 mt-6">
      <!-- Previous/Next buttons remain the same -->
    </div>
  </div>
</div>

<script>
  document.addEventListener("alpine:init", () => {
    Alpine.data("paginationComponent", () => ({
      publications: [],
      currentPage: 1,
      itemsPerPage: 2,
      totalPages: 1,

      initPublications(jsonData, itemsPerPage) {
        this.itemsPerPage = parseInt(itemsPerPage) || 2;
        this.publications = JSON.parse(jsonData);
        this.totalPages = Math.ceil(this.publications.length / this.itemsPerPage);
      },

      get paginatedPublications() {
        const start = (this.currentPage - 1) * this.itemsPerPage;
        return this.publications.slice(start, start + this.itemsPerPage);
      },

      nextPage() {
        if (this.currentPage < this.totalPages) this.currentPage++;
      },

      previousPage() {
        if (this.currentPage > 1) this.currentPage--;
      }
    }));
  });
</script>