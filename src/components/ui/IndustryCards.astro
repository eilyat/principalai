<div class="aspect-square min-w-[356px] border-box shadow-md flex flex-grow">
  <a href={href} class="flex flex-col h-full">
      <div class="relative w-full h-full bg-slate-100 hover:bg-slate-200 flex flex-col">
          <div class="absolute inset-x-0 top-0 h-6 bg-gradient-to-r from-blue-700 to-cyan-500"></div>
          <div class="flex-grow flex flex-col gap-4 md:gap-6 px-6 md:px-10 pt-8 md:pt-12 pb-8 md:pb-10 h-full justify-between">
              <h3 
                  class="text-balance text-lg font-bold text-neutral-900 leading-tight overflow-hidden truncate"
                  aria-describedby="featureDescription">
                  {title}
              </h3>
              <p
                  id="featureDescription"
                  class="flex text-pretty text-sm md:text-md overflow-hidden">
                  <slot />
              </p>
              <span class="text-xs font-semibold leading-relaxed underline underline-offset-4 relative bottom-2 grid grid-cols-8">
                <span class="col-span-7">
                    Read more about our works {cta}
                </span>
                <div class="flex items-end justify-end col-span-1">
                    <RightArrow size="20" />
                </div>
            </span>
          </div>
      </div>
  </a>
</div>
