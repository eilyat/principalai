---
const { title, subtitle } = Astro.props;

import { Breadcrumbs } from "astro-breadcrumbs";
import "astro-breadcrumbs/breadcrumbs.css";
---

<div class="relative h-[500px]">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-r from-blue-800 to-cyan-800"></div>

  <!-- Grid Layout -->
  <div class="relative z-10 max-w-screen-2xl mx-auto h-full grid grid-rows-[auto_1fr] gap-4 p-4">
    
    <!-- Breadcrumbs at the top -->
    <div class="text-white font-bold text-sm">
      <Breadcrumbs
        separatorAriaHidden={false}
        linkTextFormat="capitalized"
        class="text-white"
      >
        <svg
          slot="separator"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-white"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </Breadcrumbs>
    </div>

    <!-- Centered Title & Subtitle -->
    <div class="text-white text-left flex flex-col items-start justify-center h-full px-4 ">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-6xl font-bold mb-4 leading-normal">
        {title}
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl lg:text-3xl max-w-xl leading-relaxed">
        {subtitle}
        <slot />
      </p>
    </div>

  </div>
</div>

<!-- Custom Breadcrumb Styles -->
<style lang="scss">
  @use "astro-breadcrumbs/breadcrumbs.scss" with (
    $size-font: 14px
  );

  .astro-breadcrumbs {
    color: white !important;
  }

  .astro-breadcrumbs a {
    color: white !important;
  }

  .astro-breadcrumbs svg {
    stroke: white !important;
  }
</style>