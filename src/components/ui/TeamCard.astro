---
const { photo, name, role, location, phone, email, qualification } =
  Astro.props;
import { Icon } from "astro-icon/components";
import { Picture } from 'astro:assets';

---

<div class="shadow-md min-w-[340px]">
  <div class="w-[340px] h-[450px] relative overflow-hidden border-slate-100 border-[2px]">
  <Picture
    src={photo}
    alt={name || "No name provided"} 
    width={340}
    height={450} 
    class="object-cover w-full h-full"
    />
  </div>
  <div class="bg-slate-100 p-4 grid grid-cols-[auto,1fr] gap-4">
    test
    {
      phone && (
        <>
          <Icon name="carbon:phone" class="size-6" />
          <p class="m-0 text-lg">{phone}</p>
        </>
      )
    }
    {
      email && (
        <>
          <Icon name="carbon:email" class="size-6" />
          <p class="m-0 text-lg">
            <a href={`mailto:${email}`} class="text-blue-500 hover:underline">
              {email}
            </a>
          </p>
        </>
      )
    }
  </div>
