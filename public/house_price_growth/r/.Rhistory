`orange` = rgb(255, 127, 0, maxColorValue=255),
`lgreen` = rgb(127, 201, 127, maxColorValue=255)
)
.x <- c(...)
if (is.null(.x))
return (cols)
if(is.numeric(.x))
return(as.vector(cols[.x]))
if(is.character(cols))
return(as.vector(cols[.x]))
}
